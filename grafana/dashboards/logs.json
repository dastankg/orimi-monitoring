{
  "uid": "orimi-logs",
  "title": "Логи (Loki)",
  "tags": ["orimi", "loki", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Контейнер",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "container", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Скорость логов по контейнерам (строк/с)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "logs",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "showPoints": "never", "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (container) (rate({container=~\"$container\"}[1m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Логи",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 6 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"$container\"}"
        }
      ]
    }
  ]
}